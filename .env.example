NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

NEXT_PUBLIC_LEMON_SQUEEZY_STORE_ID=
NEXT_PUBLIC_LEMON_SQUEEZY_PRODUCT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Optional: use the Lemon Squeezy API to generate checkout URLs server-side.
LEMON_SQUEEZY_API_KEY=

# Optional provider integrations for live rotation/deployment sync.
AWS_ROTATOR_ACCESS_KEY_ID=
AWS_ROTATOR_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
VERCEL_TOKEN=
NETLIFY_TOKEN=

# Optional stale-key alert emails.
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@yourdomain.com
ALERT_TO_EMAIL=security@yourdomain.com

# Optional cron route protection.
CRON_SECRET=
